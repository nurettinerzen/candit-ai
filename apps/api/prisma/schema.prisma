  @@index([code, occurredAt(sort: Desc)])
}

model PlatformIncident {
  id          String                   @id @default(uuid())
  incidentKey String                   @unique
  tenantId    String?
  category    PlatformIncidentCategory
  severity    PlatformIncidentSeverity @default(WARNING)
  source      String
  code        String
  message     String
  status      PlatformIncidentStatus   @default(OPEN)
  firstSeenAt DateTime                 @default(now())
  lastSeenAt  DateTime                 @default(now())
  repeatCount Int                      @default(1)
  metadata    Json?
  resolvedAt  DateTime?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([status, lastSeenAt(sort: Desc)])
  @@index([tenantId, category, lastSeenAt(sort: Desc)])
  @@index([category, severity, lastSeenAt(sort: Desc)])
}

model PublicLeadSubmission {
  id                        String                     @id @default(uuid())
  status                    PublicLeadStatus           @default(NEW)
  fullName                  String
  email                     String
  normalizedEmail           String
  company                   String?
  phone                     String?
  role                      String?
  teamSize                  String?
  message                   String?
  sourcePage                String?
  landingUrl                String?
  referrerUrl               String?
  locale                    String?
  utmSource                 String?
  utmMedium                 String?
  utmCampaign               String?
  utmTerm                   String?
  utmContent                String?
  ipAddressHash             String?
  userAgent                 String?
  metadata                  Json?
  submissionCount           Int                        @default(1)
  lastSubmittedAt           DateTime                   @default(now())
  opsNotificationStatus     NotificationDeliveryStatus?
  opsNotificationProvider   String?
  opsNotificationError      String?
  opsNotificationLastTriedAt DateTime?
  opsNotificationSentAt     DateTime?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt

  @@unique([normalizedEmail])
  @@index([normalizedEmail])
  @@index([status, lastSubmittedAt(sort: Desc)])
  @@index([ipAddressHash, lastSubmittedAt(sort: Desc)])
}

model SchedulingWorkflow {
  id                        String                   @id @default(uuid())
  tenantId                  String
  applicationId             String
  sessionId                 String?
  provider                  IntegrationProvider?
  connectionId              String?
  source                    String                   @default("assistant")
  state                     SchedulingWorkflowState  @default(DRAFT)
  status                    SchedulingWorkflowStatus @default(ACTIVE)
  recruiterConstraintsJson  Json?
  candidateAvailabilityJson Json?
  proposedSlotsJson         Json?
  selectedSlotJson          Json?
  bookingResultJson         Json?
  conversationContextJson   Json?
  lastError                 String?
  initiatedBy               String
  updatedBy                 String?
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt

  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application CandidateApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  session     InterviewSession?    @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([tenantId, applicationId, createdAt(sort: Desc)])
  @@index([tenantId, status, state, updatedAt(sort: Desc)])
  @@index([tenantId, sessionId, createdAt(sort: Desc)])
}

model WorkflowJob {
  id          String         @id @default(uuid())
  tenantId    String
  type        String
  payload     Json
  status      WorkflowStatus @default(PENDING)
  runAfter    DateTime?
  attempts    Int            @default(0)
  maxAttempts Int            @default(5)
  traceId     String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  retries    WorkflowRetry[]
  aiTaskRuns AiTaskRun[]

  @@index([tenantId, status, createdAt(sort: Desc)])
}

model WorkflowRetry {
  id            String   @id @default(uuid())
  tenantId      String
  workflowJobId String
  attempt       Int
  errorMessage  String
  createdAt     DateTime @default(now())

  workflowJob WorkflowJob @relation(fields: [workflowJobId], references: [id], onDelete: Cascade)

  @@index([tenantId, workflowJobId, createdAt(sort: Desc)])
}

model DeadLetterJob {
  id            String    @id @default(uuid())
  tenantId      String
  originalJobId String
  type          String
  payload       Json
  reason        String
  replayedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([tenantId, createdAt(sort: Desc)])
}

model ApplicantFitScore {
  id              String   @id @default(uuid())
  tenantId        String
  applicationId   String
  aiTaskRunId     String?
  overallScore    Decimal
  confidence      Decimal
  subScoresJson   Json
  strengthsJson   Json?
  risksJson       Json?
  missingInfoJson Json?
  reasoningJson   Json?
  modelKey        String?
  promptVersion   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  application CandidateApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  aiTaskRun   AiTaskRun?           @relation(fields: [aiTaskRunId], references: [id], onDelete: SetNull)

  @@index([tenantId, applicationId, createdAt(sort: Desc)])
  @@index([tenantId, overallScore(sort: Desc)])
}

model RecruiterNote {
  id            String   @id @default(uuid())
  tenantId      String
  applicationId String
  authorUserId  String
  noteText      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  application CandidateApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([tenantId, applicationId, createdAt(sort: Desc)])
}
