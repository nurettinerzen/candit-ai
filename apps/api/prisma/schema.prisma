generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum Role {
  OWNER
  MANAGER
  STAFF
}

enum JobStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ApplicationStage {
  APPLIED
  SCREENING
  INTERVIEW_SCHEDULED
  INTERVIEW_COMPLETED
  RECRUITER_REVIEW
  HIRING_MANAGER_REVIEW
  OFFER
  REJECTED
  HIRED
}

enum InterviewMode {
  MEETING_LINK
  PHONE
  ONSITE
  VOICE
  VIDEO
}

enum InterviewSessionStatus {
  SCHEDULED
  RUNNING
  COMPLETED
  FAILED
  NO_SHOW
  CANCELLED
}

enum Speaker {
  AI
  CANDIDATE
  RECRUITER
}

enum Recommendation {
  ADVANCE
  HOLD
  REVIEW
}

enum AiTaskType {
  CV_PARSING
  JOB_REQUIREMENT_INTERPRETATION
  CANDIDATE_FIT_ASSISTANCE
  SCREENING_SUPPORT
  INTERVIEW_PREPARATION
  INTERVIEW_ORCHESTRATION
  TRANSCRIPT_SUMMARIZATION
  REPORT_GENERATION
  RECOMMENDATION_GENERATION
  APPLICANT_FIT_SCORING
}

enum AiTaskStatus {
  PENDING
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
  NEEDS_REVIEW
}

enum AiAutomationLevel {
  ASSISTED
  MANUAL_WITH_AI_SUPPORT
  AUTOMATED
}

enum ConsentContext {
  INTERVIEW_RECORDING
  DATA_PROCESSING
}

enum AuditActorType {
  USER
  SYSTEM
  INTEGRATION
}

enum FeatureFlagType {
  BOOLEAN
  MULTIVARIATE
  KILL_SWITCH
}

enum IntegrationProvider {
  CALENDLY
  GOOGLE_CALENDAR
  MICROSOFT_CALENDAR
  ZOOM
  GOOGLE_MEET
  ATS_GENERIC
}

enum CvExtractionStatus {
  EXTRACTED
  PARTIAL
  UNSUPPORTED
  FAILED
}

enum CvExtractionMethod {
  UTF8_PLAIN_TEXT
  PDF_PARSE
  DOCX_MAMMOTH
  DOC_LEGACY
  DOC_OS_CONVERSION
  METADATA_ONLY
}

enum SchedulingWorkflowState {
  DRAFT
  COLLECTING_RECRUITER_AVAILABILITY
  COLLECTING_CANDIDATE_AVAILABILITY
  SLOT_PROPOSAL_READY
  SLOT_SELECTED
  BOOKING_IN_PROGRESS
  BOOKED
  RESCHEDULE_PENDING
  CANCELLED
  FAILED
}

enum SchedulingWorkflowStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  FAILED
}

enum WorkflowStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  DEAD_LETTERED
}

enum DomainEventStatus {
  PENDING
  PROCESSING
  PUBLISHED
  FAILED
}

enum AuthSessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum AuthProvider {
  GOOGLE
}

enum AuthActionTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  OAUTH_LOGIN_RELAY
}

enum TranscriptQualityStatus {
  DRAFT
  REVIEW_REQUIRED
  VERIFIED
}

enum IntegrationConnectionStatus {
  ACTIVE
  INACTIVE
  ERROR
}

enum NotificationDeliveryStatus {
  QUEUED
  SENT
  FAILED
}

enum PublicLeadStatus {
  NEW
  REVIEWING
  CONTACTED
  ARCHIVED
}

enum SecurityEventSeverity {
  INFO
  WARNING
  CRITICAL
}

enum PlatformIncidentCategory {
  APPLICATION
  SECURITY
  ASSISTANT
  OPERATIONS
}

enum PlatformIncidentSeverity {
  WARNING
  CRITICAL
}

enum PlatformIncidentStatus {
  OPEN
  RESOLVED
}

enum BillingPlanKey {
  FLEX
  STARTER
  GROWTH
  ENTERPRISE
}

enum BillingAccountStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum BillingQuotaKey {
  SEATS
  ACTIVE_JOBS
  CANDIDATE_PROCESSING
  AI_INTERVIEWS
}

enum BillingGrantSource {
  PLAN
  ADDON
  MANUAL
}

enum BillingCheckoutType {
  PLAN_SUBSCRIPTION
  ADDON_PURCHASE
  ENTERPRISE_OFFER
}

enum BillingCheckoutStatus {
  OPEN
  COMPLETED
  EXPIRED
  FAILED
}

enum BillingAddonKey {
  JOB_CREDIT_PACK_1
  JOB_CREDIT_PACK_3
  CANDIDATE_PROCESSING_PACK_50
  INTERVIEW_PACK_10
  INTERVIEW_PACK_25
  CANDIDATE_PROCESSING_PACK_100
}

enum SourcingProjectStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum SourcingProspectStage {
  NEW
  NEEDS_REVIEW
  GOOD_FIT
  SAVED
  CONTACTED
  REPLIED
  CONVERTED
  REJECTED
  ARCHIVED
}

enum ProspectFitLabel {
  STRONG_MATCH
  GOOD_MATCH
  PARTIAL_MATCH
  WEAK_MATCH
  UNKNOWN
}

enum TalentSourceKind {
  INTERNAL_CANDIDATE
  PUBLIC_PROFESSIONAL
  RECRUITER_IMPORT
  REFERRAL
  OTHER
}

enum ContactSuppressionStatus {
  ALLOWED
  DO_NOT_CONTACT
  OPTED_OUT
  NEEDS_REVIEW
}

enum OutreachMessageStatus {
  DRAFT
  READY_TO_SEND
  SENT
  FAILED
  REPLIED
  CANCELLED
}

model Tenant {
  id        String       @id @default(uuid())
  name      String
  locale    String       @default("tr-TR")
  timezone  String       @default("Europe/Istanbul")
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?

  workspaces               Workspace[]
  users                    User[]
  jobs                     Job[]
  candidates               Candidate[]
  flags                    FeatureFlag[]
  audits                   AuditLog[]
  promptTemplates          AiPromptTemplate[]
  scoringRubrics           ScoringRubric[]
  aiTaskRuns               AiTaskRun[]
  recommendations          ApplicationRecommendation[]
  humanApprovals           HumanApproval[]
  domainEvents             DomainEvent[]
  authSessions             AuthSession[]
  authRefreshTokens        AuthRefreshToken[]
  authActionTokens         AuthActionToken[]
  memberInvitations        MemberInvitation[]
  userIdentities           UserIdentity[]
  externalIdentityMappings ExternalIdentityMapping[]
  integrationConnections   IntegrationConnection[]
  integrationCredentials   IntegrationCredential[]
  notificationDeliveries   NotificationDelivery[]
  schedulingWorkflows      SchedulingWorkflow[]
  sourcingProjects         SourcingProject[]
  talentProfiles           TalentProfile[]
  talentProfileSources     TalentProfileSource[]
  sourcingProjectProspects SourcingProjectProspect[]
  sourcingOutreachTemplates SourcingOutreachTemplate[]
  sourcingOutreachMessages SourcingOutreachMessage[]
  billingAccount           TenantBillingAccount?
  billingSubscriptions     TenantBillingSubscription[]
  billingQuotaGrants       BillingQuotaGrant[]
  billingUsageEvents       BillingUsageEvent[]
  billingCheckoutSessions  BillingCheckoutSession[]
  securityEvents           SecurityEvent[]
  platformIncidents        PlatformIncident[]

  @@index([createdAt(sort: Desc)])
}

model TenantBillingAccount {
  id                    String               @id @default(uuid())
  tenantId              String               @unique
  billingEmail          String?
  stripeCustomerId      String?              @unique
  currentPlanKey        BillingPlanKey       @default(STARTER)
  status                BillingAccountStatus @default(TRIALING)
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  stripeSubscriptionId  String?              @unique
  lastCheckoutSessionId String?
  currency              String               @default("usd")
  featuresJson          Json?
  planSnapshotJson      Json?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  tenant            Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscriptions     TenantBillingSubscription[]
  quotaGrants       BillingQuotaGrant[]
  usageEvents       BillingUsageEvent[]
  checkoutSessions  BillingCheckoutSession[]

  @@index([currentPlanKey, status])
}

model TenantBillingSubscription {
  id                         String               @id @default(uuid())
  tenantId                   String
  accountId                  String
  planKey                    BillingPlanKey
  status                     BillingAccountStatus
  stripeSubscriptionId       String?              @unique
  stripePriceId              String?
  stripeCheckoutSessionId    String?
  stripeCustomerId           String?
  billingEmail               String?
  periodStart                DateTime
  periodEnd                  DateTime
  seatsIncluded              Int
  activeJobsIncluded         Int
  candidateProcessingIncluded Int
  aiInterviewsIncluded       Int
  featuresJson               Json?
  metadataJson               Json?
  createdBy                  String?
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt
  canceledAt                 DateTime?

  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account     TenantBillingAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  quotaGrants BillingQuotaGrant[]

  @@index([tenantId, status, createdAt(sort: Desc)])
  @@index([accountId, createdAt(sort: Desc)])
}

model BillingQuotaGrant {
  id             String             @id @default(uuid())
  tenantId       String
  accountId      String
  subscriptionId String?
  quotaKey       BillingQuotaKey
  source         BillingGrantSource
  label          String
  quantity       Int
  consumedQuantity Int              @default(0)
  expiresAt      DateTime?
  metadataJson   Json?
  createdBy      String?
  createdAt      DateTime           @default(now())

  tenant       Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account      TenantBillingAccount      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  subscription TenantBillingSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([tenantId, quotaKey, createdAt(sort: Desc)])
  @@index([accountId, quotaKey, createdAt(sort: Desc)])
  @@index([expiresAt])
}

model BillingUsageEvent {
  id          String          @id @default(uuid())
  tenantId    String
  accountId   String
  quotaKey    BillingQuotaKey
  quantity    Int             @default(1)
  entityType  String
  entityId    String
  uniqueKey   String          @unique
  occurredAt  DateTime        @default(now())
  periodStart DateTime?
  periodEnd   DateTime?
  metadataJson Json?

  tenant  Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account TenantBillingAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([tenantId, quotaKey, occurredAt(sort: Desc)])
  @@index([accountId, quotaKey, occurredAt(sort: Desc)])
  @@index([entityType, entityId])
}

model BillingTrialClaim {
  id              String   @id @default(uuid())
  normalizedEmail String   @unique
  emailDomain     String?
  firstTenantId   String
  firstUserId     String?
  claimedAt       DateTime @default(now())
  lastSeenAt      DateTime @updatedAt
  metadataJson    Json?

  @@index([emailDomain, claimedAt(sort: Desc)])
  @@index([firstTenantId, claimedAt(sort: Desc)])
}

model BillingCheckoutSession {
  id                     String                @id @default(uuid())
  tenantId               String
  accountId              String
  checkoutType           BillingCheckoutType
  status                 BillingCheckoutStatus @default(OPEN)
  stripeCheckoutSessionId String?              @unique
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  planKey                BillingPlanKey?
  addOnKey               BillingAddonKey?
  label                  String?
  billingEmail           String?
  checkoutUrl            String?
  successUrl             String?
  cancelUrl              String?
  amountCents            Int?
  currency               String                @default("usd")
  payloadJson            Json?
  createdBy              String?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  completedAt            DateTime?
  expiresAt              DateTime?

  tenant  Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account TenantBillingAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([tenantId, checkoutType, createdAt(sort: Desc)])
  @@index([accountId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

model Workspace {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  jobs   Job[]

  @@unique([tenantId, name])
  @@index([tenantId, createdAt(sort: Desc)])
}

model User {
  id            String     @id @default(uuid())
  tenantId      String
  email         String
  fullName      String
  role          Role
  status        UserStatus @default(INVITED)
  passwordHash  String?
  passwordSetAt DateTime?
  emailVerifiedAt DateTime?
  avatarUrl     String?
  lastLoginAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  tenant                 Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  authSessions           AuthSession[]
  authRefreshTokens      AuthRefreshToken[]
  authActionTokens       AuthActionToken[]
  identities             UserIdentity[]
  memberInvitations      MemberInvitation[]  @relation("InvitationUser")
  sentMemberInvitations  MemberInvitation[]  @relation("InvitationInviter")
  securityEvents         SecurityEvent[]

  @@unique([tenantId, email])
  @@index([tenantId, role])
  @@index([tenantId, createdAt(sort: Desc)])
}

model UserIdentity {
  id              String       @id @default(uuid())
  tenantId        String
  userId          String
  provider        AuthProvider
  providerSubject String
  email           String?
  displayName     String?
  avatarUrl       String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@unique([userId, provider])
  @@index([tenantId, provider, email])
}

model MemberInvitation {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  invitedBy String
  email     String
  role      Role
  tokenHash String   @unique
  expiresAt DateTime
  acceptedAt DateTime?
  revokedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user    User   @relation("InvitationUser", fields: [userId], references: [id], onDelete: Cascade)
  inviter User   @relation("InvitationInviter", fields: [invitedBy], references: [id], onDelete: Restrict)

  @@index([tenantId, email, createdAt(sort: Desc)])
  @@index([tenantId, userId, createdAt(sort: Desc)])
  @@index([tenantId, role, createdAt(sort: Desc)])
}

model AuthSession {
  id            String            @id @default(uuid())
  tenantId      String
  userId        String
  status        AuthSessionStatus @default(ACTIVE)
  authMode      String
  expiresAt     DateTime
  lastSeenAt    DateTime?
  ipAddress     String?
  userAgent     String?
  revokedAt     DateTime?
  revokedReason String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens AuthRefreshToken[]

  @@index([tenantId, userId, status])
  @@index([tenantId, status, createdAt(sort: Desc)])
  @@index([expiresAt])
}

model AuthRefreshToken {
  id                String    @id @default(uuid())
  sessionId         String
  tenantId          String
  userId            String
  tokenHash         String    @unique
  parentTokenId     String?
  replacedByTokenId String?
  issuedAt          DateTime  @default(now())
  expiresAt         DateTime
  lastUsedAt        DateTime?
  revokedAt         DateTime?
  revokedReason     String?

  session          AuthSession        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentToken      AuthRefreshToken?  @relation("RefreshRotation", fields: [parentTokenId], references: [id], onDelete: SetNull)
  rotationChildren AuthRefreshToken[] @relation("RefreshRotation")
  replacedByToken  AuthRefreshToken?  @relation("RefreshReplacement", fields: [replacedByTokenId], references: [id], onDelete: SetNull)
  replacedTokens   AuthRefreshToken[] @relation("RefreshReplacement")

  @@index([sessionId, expiresAt])
  @@index([tenantId, userId, issuedAt(sort: Desc)])
  @@index([revokedAt])
}

model AuthActionToken {
  id         String              @id @default(uuid())
  tenantId   String?
  userId     String?
  email      String
  type       AuthActionTokenType
  tokenHash  String              @unique
  payloadJson Json?
  expiresAt  DateTime
  consumedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, type, createdAt(sort: Desc)])
  @@index([userId, type, createdAt(sort: Desc)])
  @@index([expiresAt])
}

model Job {
  id           String    @id @default(uuid())
  tenantId     String
  workspaceId  String?
  title        String
  roleFamily   String
  locationText String?
  shiftType    String?
  salaryMin    Decimal?
  salaryMax    Decimal?
  status       JobStatus @default(DRAFT)
  jdText       String?
  aiDraftText  String?
  createdBy    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  archivedAt   DateTime?

  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace    Workspace?             @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  requirements JobRequirement[]
  applications CandidateApplication[]
  aiTaskRuns   AiTaskRun[]
  sourcingProjects SourcingProject[]

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, status])
}

model JobRequirement {
  id        String   @id @default(uuid())
  tenantId  String
  jobId     String
  key       String
  value     String
  required  Boolean  @default(true)
  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([tenantId, jobId])
}

model ScreeningTemplate {
  id           String   @id @default(uuid())
  tenantId     String
  name         String
  roleFamily   String
  templateJson Json
  rubricJson   Json
  version      Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@unique([tenantId, name, version])
  @@index([tenantId, createdAt(sort: Desc)])
}

model InterviewTemplate {
  id           String   @id @default(uuid())
  tenantId     String
  name         String
  roleFamily   String
  templateJson Json
  rubricJson   Json
  version      Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  sessions InterviewSession[]

  @@unique([tenantId, name, version])
  @@index([tenantId, createdAt(sort: Desc)])
}

model Candidate {
  id                String    @id @default(uuid())
  tenantId          String
  fullName          String
  phone             String?
  email             String?
  source            String?
  locationText      String?
  yearsOfExperience Decimal?
  externalRef       String?
  externalSource    String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  tenant           Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  applications     CandidateApplication[]
  cvFiles          CVFile[]
  cvExtractionRuns CVExtractionRun[]
  consentRecords   ConsentRecord[]
  aiTaskRuns       AiTaskRun[]
  talentProfile    TalentProfile?

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, email])
}

model CandidateApplication {
  id                    String           @id @default(uuid())
  tenantId              String
  candidateId           String
  jobId                 String
  currentStage          ApplicationStage
  stageUpdatedAt        DateTime
  aiRecommendation      Recommendation?
  humanDecisionRequired Boolean          @default(true)
  createdAt             DateTime         @default(now())

  candidate           Candidate                   @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job                 Job                         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  stageHistory        CandidateStageHistory[]
  interviewSessions   InterviewSession[]
  aiReports           AiReport[]
  aiTaskRuns          AiTaskRun[]
  recommendations     ApplicationRecommendation[]
  fitScores           ApplicantFitScore[]
  recruiterNotes      RecruiterNote[]
  schedulingWorkflows SchedulingWorkflow[]

  @@unique([tenantId, candidateId, jobId])
  @@index([tenantId, jobId, currentStage])
}

model TalentProfile {
  id                   String                   @id @default(uuid())
  tenantId             String
  candidateId          String?                  @unique
  fullName             String
  normalizedEmail      String?
  normalizedPhone      String?
  email                String?
  phone                String?
  headline             String?
  summary              String?
  locationText         String?
  currentTitle         String?
  currentCompany       String?
  yearsOfExperience    Decimal?
  workModel            String?
  salaryExpectationMin Decimal?
  salaryExpectationMax Decimal?
  sourceKind           TalentSourceKind        @default(OTHER)
  primarySourceLabel   String?
  suppressionStatus    ContactSuppressionStatus @default(ALLOWED)
  doNotContactReason   String?
  skillTagsJson        Json?
  languageTagsJson     Json?
  educationJson        Json?
  experienceJson       Json?
  contactSignalsJson   Json?
  marketSignalsJson    Json?
  sourceMetadataJson   Json?
  lastEnrichedAt       DateTime?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  tenant        Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  candidate     Candidate?                @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  sourceRecords TalentProfileSource[]
  projectLinks  SourcingProjectProspect[]

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, sourceKind])
  @@unique([tenantId, normalizedEmail])
  @@unique([tenantId, normalizedPhone])
}

model TalentProfileSource {
  id             String            @id @default(uuid())
  tenantId       String
  talentProfileId String
  sourceKind     TalentSourceKind
  providerKey    String
  providerLabel  String
  displayName    String
  externalRef    String?
  sourceUrl      String?
  isPrimary      Boolean           @default(false)
  isVerified     Boolean           @default(false)
  lastSeenAt     DateTime?
  metadataJson   Json?
  createdAt      DateTime          @default(now())

  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  talentProfile TalentProfile @relation(fields: [talentProfileId], references: [id], onDelete: Cascade)

  @@index([tenantId, talentProfileId, createdAt(sort: Desc)])
  @@index([tenantId, sourceKind, providerKey])
}

model SourcingProject {
  id             String               @id @default(uuid())
  tenantId       String
  jobId          String?
  name           String
  personaSummary String?
  searchQuery    String?
  filtersJson    Json?
  notes          String?
  status         SourcingProjectStatus @default(ACTIVE)
  stageGoalsJson Json?
  createdBy      String
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  archivedAt     DateTime?

  tenant            Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  job               Job?                      @relation(fields: [jobId], references: [id], onDelete: SetNull)
  prospects         SourcingProjectProspect[]
  outreachTemplates SourcingOutreachTemplate[]

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, jobId])
  @@index([tenantId, status])
}

model SourcingProjectProspect {
  id                   String               @id @default(uuid())
  tenantId             String
  projectId            String
  talentProfileId      String
  attachedCandidateId  String?
  attachedApplicationId String?
  stage                SourcingProspectStage @default(NEEDS_REVIEW)
  fitLabel             ProspectFitLabel     @default(UNKNOWN)
  fitScore             Decimal?
  fitConfidence        Decimal?
  strengthsJson        Json?
  risksJson            Json?
  missingInfoJson      Json?
  evidenceJson         Json?
  recruiterNote        String?
  contactState         String?
  sourceSnapshotJson   Json?
  lastReviewedAt       DateTime?
  contactedAt          DateTime?
