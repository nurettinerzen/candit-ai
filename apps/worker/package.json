  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bullmq": "^5.49.1",
    "dotenv": "^16.4.7",
    "ioredis": "^5.6.1",
    "mammoth": "^1.9.1",
    "pdf-parse": "^1.1.4",
    "word-extractor": "^1.0.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
