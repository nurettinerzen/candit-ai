{
  "name": "ai-interviewer",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "corepack pnpm -r --parallel --if-present dev",
    "build": "corepack pnpm db:generate && corepack pnpm -r --if-present build",
    "lint": "corepack pnpm -r --if-present lint",
    "test": "corepack pnpm -r --if-present test",
    "test:contracts": "corepack pnpm --filter @ai-interviewer/api test:contracts && corepack pnpm --filter @ai-interviewer/web test:contracts && corepack pnpm --filter @ai-interviewer/worker test:contracts",
    "launch:verify": "corepack pnpm db:generate && corepack pnpm lint && corepack pnpm test && corepack pnpm build",
    "launch:verify:contracts": "corepack pnpm test:contracts",
    "launch:verify:runtime": "node scripts/pilot-smoke.mjs",
    "launch:verify:runtime:strict": "CANDIT_SMOKE_STRICT=1 node scripts/pilot-smoke.mjs",
    "smoke:pilot": "node scripts/pilot-smoke.mjs",
    "smoke:billing": "corepack pnpm --filter @ai-interviewer/api smoke:billing",
    "format": "corepack pnpm -r --if-present format",
    "i18n:audit": "node scripts/translate-audit.mjs",
    "db:generate": "corepack pnpm --filter @ai-interviewer/api prisma:generate",
    "db:migrate": "corepack pnpm --filter @ai-interviewer/api prisma:migrate:dev",
    "db:seed": "corepack pnpm --filter @ai-interviewer/api prisma:seed"
  }
}
