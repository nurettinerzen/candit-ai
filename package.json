{
  "name": "ai-interviewer",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "corepack pnpm -r --parallel --if-present dev",
    "build": "corepack pnpm -r --if-present build",
    "lint": "corepack pnpm -r --if-present lint",
    "test": "corepack pnpm -r --if-present test",
    "launch:verify": "corepack pnpm db:generate && corepack pnpm lint && corepack pnpm test && corepack pnpm build",
    "format": "corepack pnpm -r --if-present format",
    "i18n:audit": "node scripts/translate-audit.mjs",
    "db:generate": "corepack pnpm --filter @ai-interviewer/api prisma:generate",
    "db:migrate": "corepack pnpm --filter @ai-interviewer/api prisma:migrate:dev",
    "db:seed": "corepack pnpm --filter @ai-interviewer/api prisma:seed"
  }
}
